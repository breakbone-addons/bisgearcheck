package-as: BISGearCheck

ignore:
  - README.md
  - LICENSE
  - .github
  - .gitignore
  - .pkgmeta
  - CHANGELOG.md

externals:
  libs/LibStub:
    url: https://repos.wowace.com/wow/libstub/trunk
    tag: latest
  libs/CallbackHandler-1.0:
    url: https://repos.wowace.com/wow/callbackhandler/trunk/CallbackHandler-1.0
    tag: latest
  libs/LibDataBroker-1.1:
    url: https://github.com/tekkub/libdatabroker-1-1
    tag: latest
  libs/LibDBIcon-1.0:
    url: https://repos.wowace.com/wow/libdbicon-1-0/trunk/LibDBIcon-1.0
    tag: latest

enable-nolib-creation: yes

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
